---
import '../styles/global.css'

interface Props {
    title: string;
}
const {title} = Astro.props;
const base = import.meta.env.BASE_URL // whatever url is in astro.config.mjs
const tabs = [ // these guys tack on to the main url!!
    {name: 'About me', href: `${base}about/`},
    {name: 'Experience', href: `${base}experience/`},
    {name: 'Yale', href: `${base}yale/`},
    {name: 'Projects', href: `${base}projects/`},
    {name: 'Greenhaven', href: `${base}greenhaven/`},
    {name: 'Art', href: `${base}art/`},
]
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device=width, initial-scale=1.0" />

    <title>{title} - Afomia Mesfin</title>
    <!-- load the Fraunces & Inter fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@400;500&display=swap" rel="stylesheet">

    <!-- favicon, so the tab has a lil logo! -->
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`}>
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`}>
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`}>
    <link rel="manifest" href={`${base}site.webmanifest`}>
</head>

<body class="bg-navy text-white font-sans min-h-screen">
    <div class="flex flex-col md:flex-row min-h-screen">
        <nav class="md:w-64 shrink-0 p-8 md:p-12">
            <a href={base} class="font-serif text-2xl font-light block mb-12 hover:text-teal transition-colors">
                Afomia Mesfin
            </a>

            <ul class="space-y-6">
                {tabs.map((tab) => {
                // loops over array of tabs above
                const isActive = currentPath.replace(/\/$/, '') === tab.href.replace(/\/$/, '');
                return (
                    <li>
                        <a
                        href={tab.href}
                        class:list={[
                        "font-serif text-4xl font-light transition-colors",
                        isActive ? "text-teal" : "text-white hover:text-teal"
                        ]}
                    >
                        {tab.name}
                    </a>   
                    </li>
                )
                })}
            </ul>
        </nav>

    <main class="flex-1 p-8 md:p-16 pb-24">
        <slot /> <!-- placeholder for content display based on current page -->
    </main>
    </div>

    <footer class="fixed bottom-6 left-8 flex gap-4 text-2xl font-sans z-10">
        <a href={`${base}Afomia Mesfin Resume.pdf`} download class="text-cream hover:text-teal transition-colors" >
            Resume
        </a>

        <button id="email-trigger" class="text-white hover:text-teal transition-colors ">
            Email
        </button>

        <a href="https://www.linkedin.com/in/afomia-mesfin/" target="_blank" rel="noopener noreferrer"
            class="text-white hover:text-teal transition-colors ">
            Linkedin
        </a>

        <dialog id="email-popup" class="backdrop:bg-black/50 bg-white text-navy rounded-lg p-0 w-full max-w-md">
        </dialog>
    
    </footer>

</body>

</html>
