---
import '../styles/global.css'

interface Props {
    title: string;
}
const {title} = Astro.props;
const base = import.meta.env.BASE_URL; // for me BASE_URL is /portfolio/

const navLinks = [
    {name: '⤷ about', href: '#about'},
    {name: '⤷ experience', href: '#experience'},
    {name: '⤷ education', href: '#education'},
    {name: '⤷ projects', href: '#projects'},
    {name: '⤷ art', href: '#art'}
]
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <!-- meta stuff, import fraunces font, setup site icon!! -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title> {title} - Afomia Mesfin </title>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

        <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`}>
        <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`}>
        <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`}>
        <link rel="manifest" href={`${base}site.webmanifest`}>
    </head>

    <body class="bg-bg text-text font-sans">
        <!-- nav bar -->
        <header class="sticky top-0 z-50 bg-bg/90 px-8 py-5 flex items-center justify-between">
            <a href="#about" class="font-serif text-2xl font-light">Afomia Mesfin</a>

            <!-- desktop links (hidden om mobile by defaunt) -->
            <nav class="hidden font-serif md:flex gap-8">
                {navLinks.map((link) => (
                <a href={link.href} class="text-sm text-text transition-colors">{link.name}</a>
            ))}
            </nav>

            <!-- hamburger button, hidden on desktop -->
            <button id="menu-toggle" class="md:hidden" aria-label="Toggle menu">
                <div class="w-6 h-0.5 bg-current mb-1.5"></div>
                <div class="w-6 h-0.5 bg-current mb-1.5"></div>
                <div class="w-6 h-0.5 bg-current"></div>
            </button>

            <!-- mobile menu, starts hidden -->
            <nav id="mobile-menu" class="hidden flex-col gap-3 px-8 pb-6 bg-bg absolute top-full left-0 w-full">
                {navLinks.map((link) => (
                    <a href={link.href} class="mobile-link font-serif text-lg text-text hover:text-text transition-colors">{link.name}</a>
                ))}
            </nav>
        </header>

        <script>
            const copyBtn = document.getElementById('copy-email-btn');

            copyBtn?.addEventListener('click', async () => {
                await navigator.clipboard.writeText('afomia.mesfin@yale.edu');

                // brief visual feedback so the user knows it worked
                const original = copyBtn.textContent;
                copyBtn.textContent = 'Copied :)';
                setTimeout(() => {
                    copyBtn.textContent = original;
                }, 1500);
            });
        </script>

        <!-- page content -->
        <main>
            <slot />
        </main>

        <footer class="text-center px-8 py-12 text-sm font-serif text-muted">
            Built and designed by Afomia Mesfin. <br>
            All rights reserved. ©
        </footer>
    </body>

    <script>
        // open / close mobile menu
        const menuBtn = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');

        menuBtn?.addEventListener('click', () => {
            const isHidden = menu?.classList.contains('hidden');
            if(isHidden){
                menu?.classList.remove('hidden')
                menu?.classList.add('flex')
                menuBtn?.classList.add('text-accent')
            } else {
                menu?.classList.remove('flex')
                menu?.classList.add('hidden')
                menuBtn?.classList.remove('text-accent')
            }
        })

        // close menu when link is tapped
        document.querySelectorAll('.mobile-link').forEach((link) => {
            link.addEventListener('click', () => {
                menu?.classList.add('hidden')
                menu?.classList.remove('flex')
                menu?.classList.remove('color-accent')
            })
        })
    </script>

</html>