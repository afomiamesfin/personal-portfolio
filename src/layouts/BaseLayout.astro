---
import '../styles/global.css'

interface Props {
    title: string;
}
const {title} = Astro.props;
const base = import.meta.env.BASE_URL; // for me BASE_URL is /portfolio/

const navLinks = [
    {name: 'about', href: '#about'},
    {name: 'experience', href: '#experience'},
    {name: 'education', href: '#education'},
    {name: 'projects', href: '#projects'},
    {name: 'art', href: '#art'}
]
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <!-- meta stuff, import fraunces font, setup site icon!! -->
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale-1.0" />
        <title> {title} - Afomia Mesfin </title>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@400;500&display=swap" rel="stylesheet">

        <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`}>
        <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`}>
        <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`}>
        <link rel="manifest" href={`${base}site.webmanifest`}>
    </head>

    <body class="bg-bgrnd text-titles font-sans">
        <!-- nav bar -->
        <header class="sticky top-0 z-50 bg-bgrnd/90 px-8 py-5 flex items-center justify-between">
            <a href="#about" class="font-serif text-2xl font-light"></a>

            <!-- desktop links (hidden om mobile by defaunt) -->
            <nav class="hidden md:flex gap-8">
                {navLinks.map((link) => (
                <a href={link.href} class="text-sm text-titles transition-colors">{link.name}</a>
            ))}
            </nav>

            <!-- hamburger button, hidden on desktop -->
            <button id="menu-toggle" class="md:hidden" aria-label="Toggle menu">
                <div class="w-6 h-0.5 bg-text1 mb-1.5"></div>
                <div class="w-6 h-0.5 bg-text1 mb-1.5"></div>
                <div class="w-6 h-0.5 bg-text1"></div>
            </button>
        </header>

        <!-- mobile menu, starts hidden -->
        <nav id="mobile-menu" class="hidden md:hidden flex-col gap-4 px-8 pb-6 bg-bgrnd">
            {navLinks.map((link) => (
                <a href={link.href} class="mobile-link text-base text-text1 hover:text-text1 transition-colors">{link.name}</a>
            ))}
        </nav>

        <!-- page content -->
        <main>
            <slot />
        </main>
    </body>

    <script>
        // open / close mobile menu
        const menuBtn = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');

        menuBtn?.addEventListener('click', () => {
            menu?.classList.toggle('hidden');
        })

        // close menu when link is tapped
        document.querySelectorAll('.mobile-link').forEach((link) => {
            link.addEventListener('click', () => {
                menu?.classList.toggle('hidden');
            })
        })
    </script>

</html>