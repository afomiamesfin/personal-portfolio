---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL; // for me BASE_URL is /portfolio/

const experience = [
    {
        company: "Qonqr",
        role: "Software Engineer Intern",
        dates: "JUNE 2026 - PRESENT ",
        bullets: [
            "Modernized the UI of a live cross-platform mobile game spanning 3M+ battle zones across 250+ countries, refactoring panels, popups, and map overlays, by migrating the legacy Xamarin & C# codebase to .NET MAUI",
            "Improved UI consistency across iOS platforms, aligning components with current framework standards, by rebuilding interface elements in XAML"
        ]
    },
    {
        company: "SPS Commerce",
        role: "Microsoft Market Team Intern",
        dates: "JUNE 2025 - AUGUST 2025",
        bullets: [
            "Enabled global client onboarding by resolving 44 Salesforce support tickets and configuring 5+ new data environments for 20+ clients across 4 continents",
            "Strengthened cross-team technical workflows and cloud environment management by utilizing Jira, Confluence, Postman, VMWare, and mRemoteNG",
            "Built foundational cloud and data infrastructure expertise, completing Microsoft Azure Fundamentals coursework, through a 3-day technical bootcamp covering EDI, DEMEDI methodology, and SQL Server Management Studio"
        ]
    },
    {
        company: "KnightKrawler Robotics",
        role: "Autonomous Controls Lead (2025), Team Operations Captain (2026)",
        dates: "SEP 2023 - MAY 2026",
        bullets: [
            "Produced flexible and efficient Java-based autonomous robotics software using tools like Pathplanner",
            "Standardized onboarding by authoring 53 software and executive training documents"
        ]
    }
]

const education = [
    {
        school: "Yale College",
        dates: "AUG 2026 - MAY 2030",
        courses: [
            "coming soon :)"
        ],
        ecs: [
            "coming soon :)"
        ]
    },
    {
        school: "Irondale Senior High School",
        dates: "SEP 2022 - May 2026",
        courses: [
            "AP Human Geography, AP US History, AP World History, AP Comparative Government",
            "AP Macroeconomics, AP Calculus AB & BC; AP Computer Science, AP Statistics, AP Physics C: Mechanics",
            "AP Biology, AP Psychology",
            "AP Language & Composition, AP Literature & Composition"
        ],
        ecs: [
            "KnightKrawler Robotics (Autonomous Lead, Team Operations Captain)",
            "Irondale Women Empowerment (Co-Founder & President)",
            "Student Government Exec (Outreach Coordinator)",
            "Swim & Dive (Varsity Diving Captain)"
        ]
    }
]
---
<BaseLayout title="home">

    <!-- about -->
    <section id="about" class="items-center gap-12 text-4xl pt-24 pb-12 px-8 flex flex-col md:flex-row justify-center font-serif">
        <!-- photo -->
        <img
            src={`${base}headshot.png`}
            alt="Afomia Mesfin"
            class="w-75 h-75 rounded-2xl bg-card border border-accent shrink-0 object-cover">
        <!-- text -->
        <div>
            <h1 class="text-4xl mb-6 text-accent">Welcome!</h1>
            <p class="leading-relaxed text-lg text-muted font-serif w-xl mb-6">
                I'm <span class="text-accent">Afomia Mesfin</span>, an 18-year-old <span class="text-accent">developer, 
                artist, and climate-tech enthusiast</span> from <span class="text-accent">Ethiopia</span> and New Brighton, <span class="text-accent">Minnesota</span> !! 
                I'm passionate about the <span class="text-accent">ethicality, environmental impact, and social influence</span> of <span class="text-accent">tech</span> development. 
                I'm currently a first-year student at <span class="text-accent">Yale ('30) </span> studying <span class="text-accent">Computer Science </span> and <span class="text-accent">Climate Science & Solutions. </span>
                I am always <span class="text-accent">open to collaborate</span> or take on any <span class="text-accent">new projects ᕙ( •̀ ᗜ •́ )ᕗ</span>
            </p>
            <!-- buttons -->
            <div class="flex flex-wrap gap-3">
                <button
                    id="copy-email-btn"
                    class="inline-flex items-center gap-2 border border-accent text-accent rounded-lg px-5 py-2.5 text-sm font-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="20" height="16" x="2" y="4" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                Say hi!
                </button>
                <a 
                    href="https://www.linkedin.com/in/afomia-mesfin/" 
                    target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 border border-accent text-accent rounded-lg px-5 py-2.5 text-sm font-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                        <rect width="4" height="12" x="2" y="9"/>
                        <circle cx="4" cy="4" r="2"/>
                    </svg>
                Linkedin
                </a>
                <a 
                    href="https://github.com/afomiamesfin" 
                    target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 border border-accent text-accent rounded-lg px-5 py-2.5 text-sm font-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                    </svg>
                Github 
                </a>
                <a 
                    href= {`${base}afomia-mesfin-resume.pdf`}
                    target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 border border-accent text-accent rounded-lg px-5 py-2.5 text-sm font-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                Download Resume
                </a>
            </div>
        </div>
    </section>

    <!-- experience -->
    <section id="experience" class="pt-24 pb-12 px-8 flex justify-center">
        <div class="w-full max-w-4xl lg:max-w-6xl">
            <h1 class="font-serif text-4xl font-light text-text mb-6">/ experience</h1>
            <div class="flex gap-10 w-4xl">
                <!-- left: button list stacked vertically -->
                <div class="flex flex-col gap-1 w-32 md-48 shrink-0">
                    {experience.map((job) => (
                        <button data-company={job.company} 
                            class:list={[
                                "experience-tab text-left py-2.5 pl-4 border-l-2 text-sm md:text-base",
                                job === experience[0] ? "border-accent text-accent" : "border-border text-muted",
                            ]}
                        >
                            {job.company}
                        </button>
                    ))}
                </div>

                 <!-- right: data -->
                <div class="flex-1">
                    {experience.map((job) => (
                        <div data-company={job.company} 
                        class:list={["experience-panel mb-10", job !== experience[0] && "hidden"]}>
                            <h3 class="font-serif text-2xl font-light text-text">
                                {job.role} <span class="text-accent">@ {job.company} </span>
                            </h3>
                            <p class="text-sm text-muted mb-4">
                                {job.dates}
                            </p>
                            <ul class="space-y-2">
                                {job.bullets.map((bullet) => 
                                        <li class="text-muted leading-relaxed"><span class="text-accent">⤷ </span>{bullet}</li>
                                )}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- education -->
    <section id="education" class="py-15 px-8 flex justify-center">
        <div class="w-full max-w-4xl lg:max-w-6xl">
            <h1 class="font-serif text-4xl font-light text-text mb-6">/ education</h1>
            <div class="flex gap-10 w-4xl">
                <!-- left: button list stacked vertically -->
                <div class="flex flex-col gap-1 w-32 md-48 shrink-0">
                    {education.map((edu) => (
                        <button data-school={edu.school} 
                            class:list={[
                                "education-tab text-left py-2.5 pl-4 border-l-2 text-sm md:text-base",
                                edu === education[0] ? "border-accent text-accent" : "border-border text-muted",
                            ]}
                        >
                            {edu.school}
                        </button>
                    ))}
                </div>

                 <!-- right: data -->
                <div class="flex-1">
                    {education.map((edu) => (
                        <div data-school={edu.school} 
                        class:list={["education-panel mb-10", edu !== education[0] && "hidden"]}>
                            <h3 class="font-serif text-2xl font-light text-text">
                                {edu.school}
                            </h3>
                            <p class="text-sm text-muted mb-4">
                                {edu.dates}
                            </p>
                            <h2 class="font-serif text-lg font-light text-text">Relevant Coursework</h2>
                            <ul class="space-y-1 mb-5">
                                {edu.courses.map((course) => 
                                        <li class="text-muted leading-relaxed"><span class="text-accent">⤷ </span>{course}</li>
                                )}
                            </ul>
                            <h2 class="font-serif text-lg font-light text-text">Extracurriculars</h2>
                            <ul class="space-y-2">
                                {edu.ecs.map((ec) => 
                                        <li class="text-muted leading-relaxed"><span class="text-accent">⤷ </span>{ec}</li>
                                )}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- projects -->
    <section id="projects" class="py-15 px-8 flex justify-center">
        <div class="w-full max-w-4xl lg:max-w-6xl">
            <h1 class="font-serif text-4xl font-light text-text mb-6">/ projects</h1>
            <p class="leading-relaxed text-xl text-muted font-serif">
                [Filler] personal projects including greenhaven
            </p>
        </div>
    </section>

    <!-- art -->
    <section id="art" class="py-15 px-8 flex justify-center">
        <div class="w-full max-w-4xl lg:max-w-6xl">
            <h1 class="font-serif text-4xl font-light text-text mb-6">/ art</h1>
            <p class="leading-relaxed text-xl text-muted font-serif">
                [Filler] Painting gallery — title, date, featured at.
            </p>
        </div>
    </section>
</BaseLayout>